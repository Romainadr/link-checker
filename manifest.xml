<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <Id>73cbd09c-f705-4278-af6c-dd949a310e28</Id>
  <Version>1.0.0.6</Version>
  <ProviderName>EMPIRYS</ProviderName>
  <DefaultLocale>fr-FR</DefaultLocale>
  <DisplayName DefaultValue="Link Checker"/>
  <Description DefaultValue="Verifie que les liens affiches dans un mail correspondent aux URLs reelles."/>

  <IconUrl DefaultValue="https://romainadr.github.io/link-checker/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://romainadr.github.io/link-checker/icon-128.png"/>
  <SupportUrl DefaultValue="https://empirys.com"/>

  <AppDomains>
    <AppDomain>https://romainadr.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://romainadr.github.io/link-checker/src/taskpane.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <!-- VersionOverrides V1_1 : bouton ruban + activation evenementielle automatique -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.10">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="LC.Cmd.Url"/>

          <!-- Declenchement automatique a l'ouverture d'un email -->
          <ExtensionPoint xsi:type="LaunchEvent">
            <LaunchEvents>
              <LaunchEvent Type="OnMessageRead" FunctionName="onMessageRead"/>
            </LaunchEvents>
            <SourceLocation resid="LC.Cmd.Url"/>
          </ExtensionPoint>

          <!-- Bouton ruban pour voir le detail -->
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="lc.grp1">
                <Label resid="LC.Grp.Label"/>
                <Control xsi:type="Button" id="lc.btn1">
                  <Label resid="LC.Btn.Label"/>
                  <Supertip>
                    <Title resid="LC.Btn.Label"/>
                    <Description resid="LC.Btn.Tip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="LC.Icon.16"/>
                    <bt:Image size="32" resid="LC.Icon.32"/>
                    <bt:Image size="80" resid="LC.Icon.80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="LC.Taskpane.Url"/>
                    <SupportsPinning>true</SupportsPinning>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="LC.Icon.16" DefaultValue="https://romainadr.github.io/link-checker/icon-16.png"/>
        <bt:Image id="LC.Icon.32" DefaultValue="https://romainadr.github.io/link-checker/icon-32.png"/>
        <bt:Image id="LC.Icon.80" DefaultValue="https://romainadr.github.io/link-checker/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="LC.Cmd.Url" DefaultValue="https://romainadr.github.io/link-checker/src/commands.html"/>
        <bt:Url id="LC.Taskpane.Url" DefaultValue="https://romainadr.github.io/link-checker/src/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="LC.Grp.Label" DefaultValue="Link Checker"/>
        <bt:String id="LC.Btn.Label" DefaultValue="Verifier les liens"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="LC.Btn.Tip" DefaultValue="Verifie si les URLs reelles correspondent au texte affiche."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>

</OfficeApp>
